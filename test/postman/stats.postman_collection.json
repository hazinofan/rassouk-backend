    {
      "name": "03 - Employer Overview",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/employers/{{tenantId}}/overview?range=30d",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "employers",
            "{{tenantId}}",
            "overview"
          ],
          "query": [
            {
              "key": "range",
              "value": "30d"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Overview shape', function () {",
              "  pm.expect(json).to.have.property('views');",
              "  pm.expect(json).to.have.property('clicks');",
              "  pm.expect(json).to.have.property('applications');",
              "  pm.expect(json).to.have.property('topJobs');",
              "  pm.expect(json.topJobs).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
