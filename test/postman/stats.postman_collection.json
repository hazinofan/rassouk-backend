{
  "info": {
    "name": "Rassouk Backend - Stats",
    "_postman_id": "a5afec1a-e3e2-4755-8c73-8c98f7f1a1a2",
    "description": "Stats and tracking endpoints smoke tests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Track View",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"jobId\": {{jobId}},\n  \"tenantId\": {{tenantId}},\n  \"sessionId\": \"pm-session-{{$timestamp}}\",\n  \"source\": \"postman\",\n  \"referrer\": \"https://postman.local\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/track/view",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "track",
            "view"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201/200', function () {",
              "  pm.expect([200, 201]).to.include(pm.response.code);",
              "});",
              "const json = pm.response.json();",
              "pm.test('ok=true', function () {",
              "  pm.expect(json.ok).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
